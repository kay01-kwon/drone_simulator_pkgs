<?xml version="1.0"?>
<sdf version="1.8">
  <model name="att_model">
    <!-- Initial pose -->
    <pose>0 0 0 0 0 0</pose>

    <!-- Body link (attitude test variant: measured mass/CoM/inertia) -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <!-- Center of mass: 1.5, 0.34, 32.9 mm -->
        <pose>0.0015 0.00034 0.0329 0 0 0</pose>
        <mass>2.405</mass>
        <!-- Inertia about CoM, converted from g*mm^2 (x1e-9) to kg*m^2 -->
        <inertia>
          <ixx>0.05279912783</ixx>
          <ixy>0.00005806041</ixy>
          <ixz>0.00004497693</ixz>
          <iyy>0.05221052872</iyy>
          <iyz>0.00051803523</iyz>
          <izz>0.09865590814</izz>
        </inertia>
      </inertial>
      <collision name="base_link_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.255 0.28845 0.545</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1.0</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.003</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>1.2</mu>
              <mu2>1.2</mu2>
              <fdir1>0 0 0</fdir1>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="base_link_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>package://drone_description/models/S550/meshes/S550.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- IMU link (52mm above base_link) -->
    <link name="imu_link">
      <pose relative_to="base_link">0 0 0.052 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-9</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-9</iyy>
          <iyz>0</iyz>
          <izz>1e-9</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>200.0</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.63e-4</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>1.5e-4</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.63e-4</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>1.5e-4</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.63e-4</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>1.5e-4</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.86e-3</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>8.0e-3</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.86e-3</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>8.0e-3</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>6.86e-3</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0</bias_stddev>
                <dynamic_bias_stddev>8.0e-3</dynamic_bias_stddev>
                <bias_correlation_time>3000.0</bias_correlation_time>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <!-- Camera link -->
    <link name="bottom_screw_frame">
      <pose relative_to="base_link">
        0.046 0 -0.088
        0 0.52359877559 0
      </pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1e-10</mass>
        <inertia>
          <ixx>1e-10</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-10</iyy>
          <iyz>0</iyz>
          <izz>1e-10</izz>
        </inertia>
      </inertial>
    </link>

    <link name="camera_link">
      <pose relative_to="bottom_screw_frame">
        0 0.0175 0.0125
        0 0 0
      </pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1e-10</mass>
        <inertia>
          <ixx>1e-10</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-10</iyy>
          <iyz>0</iyz>
          <izz>1e-10</izz>
        </inertia>
      </inertial>
      <collision name="camera_collision">
        <pose>0 0 0
              0 0 0
        </pose>
        <geometry>
          <box>
            <size>0.090 0.025 0.025</size>
          </box>
        </geometry>
      </collision>
      <visual name="camera_visual">
        <pose relative_to="camera_link">
          0.0149 -0.0175 0
          1.57079632679 0 1.57079632679
        </pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>package://drone_description/models/S550/meshes/d435.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name="camera_ir_frame">
      <pose relative_to="camera_link">
        0 0 0
        0 0 0
      </pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1e-10</mass>
        <inertia>
          <ixx>1e-10</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-10</iyy>
          <iyz>0</iyz>
          <izz>1e-10</izz>
        </inertia>
      </inertial>
    </link>

    <link name="camera_ir_optical_frame">
      <pose relative_to="camera_ir_frame">
        0 0 0
        -1.57079632679 0 -1.57079632679
      </pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1e-10</mass>
        <inertia>
          <ixx>1e-10</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-10</iyy>
          <iyz>0</iyz>
          <izz>1e-10</izz>
        </inertia>
      </inertial>
      <sensor name="camera_left_ir_sensor" type="camera">
        <pose relative_to="camera_ir_frame">
          0 0 0
          0 0 0
        </pose>
        <topic>camera/infra1/image_rect_raw</topic>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <enable_metrics>false</enable_metrics>
        <camera>
          <horizontal_fov>1.3742478184</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>L_INT8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
          </distortion>
        </camera>
      </sensor>
      <sensor name="camera_right_ir_sensor" type="camera">
        <pose relative_to="camera_ir_frame">
          0 -0.050 0
          0 0 0
        </pose>
        <topic>camera/infra2/image_rect_raw</topic>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <enable_metrics>false</enable_metrics>
        <camera>
          <horizontal_fov>1.3742478184</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>L_INT8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
          </distortion>
        </camera>
      </sensor>
    </link>

    <link name="camera_depth_frame">
      <pose relative_to="camera_link">
        0.015 0 0
        0 0 0
      </pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1e-10</mass>
        <inertia>
          <ixx>1e-10</ixx>
