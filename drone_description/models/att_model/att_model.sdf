      <child>camera_ir_optical_frame</child>
    </joint>

    <joint name="camera_depth_frame_joint" type="fixed">
      <parent>camera_link</parent>
      <child>camera_depth_frame</child>
    </joint>

    <joint name="camera_depth_optical_frame_joint" type="fixed">
      <parent>camera_depth_frame</parent>
      <child>camera_depth_optical_frame</child>
    </joint>

